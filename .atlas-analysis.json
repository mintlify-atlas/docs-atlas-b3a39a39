  "keyFeatures": [
    "Unified stream and batch processing on a single runtime",
    "Event-time processing with out-of-order event support (Dataflow Model)",
    "Stateful computations with exactly-once fault-tolerance guarantees",
    "Flexible windowing: tumbling, sliding, session, and custom triggers",
    "SQL and Table API for declarative data processing",
    "Python API (PyFlink) for Python-native development",
    "Native Kubernetes, YARN, and standalone cluster deployment",
    "Checkpoints and savepoints for operational state management",
    "Rich connector ecosystem including Kafka, filesystems, and JDBC",
    "Adaptive batch execution and speculative execution for optimization"
  ],
  "publicApiSurface": [
    "StreamExecutionEnvironment — entry point for DataStream API programs",
    "DataStream<T> — core abstraction for streaming data transformations",
    "TableEnvironment — entry point for Table API and SQL programs",
    "Table — relational abstraction for Table API queries",
    "StatementSet — batch SQL execution interface",
    "DataStreamSource<T> — source connector abstraction",
    "SinkFunction<T> / Sink<T> — sink connector abstraction",
    "KeyedStream<T, KEY> — partitioned stream for stateful operations",
    "WindowedStream — stream partitioned by key and window",
    "ProcessFunction<I, O> — low-level stream processing with timers and state",
    "RuntimeExecutionMode (STREAMING, BATCH, AUTOMATIC)",
    "WatermarkStrategy — watermark generation for event-time processing",
    "CheckpointConfig — checkpoint configuration",
    "StateBackend — pluggable state storage (HashMapStateBackend, EmbeddedRocksDBStateBackend)",
    "FlinkKafkaConsumer / FlinkKafkaProducer — Kafka connector",
    "FileSource / FileSink — file system connector",
    "StreamTableEnvironment — bridge between DataStream and Table API"
  ]
}
